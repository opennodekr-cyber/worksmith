---
import BaseLayout from './BaseLayout.astro';
import { CATEGORIES } from '@/consts';
import type { CollectionEntry } from 'astro:content';
import NewsletterCTA from '@components/NewsletterCTA.astro';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, publishedAt, updatedAt, category, tags, experience, affiliateLinks } =
  post.data;

const categoryMeta = CATEGORIES.find((c) => c.slug === category);

const fmt = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishedAt.toISOString(),
  dateModified: (updatedAt ?? publishedAt).toISOString(),
  author: { '@type': 'Person', name: post.data.author },
  inLanguage: 'ko-KR',
};
---

<BaseLayout title={title} description={description} type="article">
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(structuredData)}
  />

  <article class="container-prose py-12">
    <header class="mb-10">
      <a
        href={`/categories/${category}`}
        class="inline-block text-sm text-muted no-underline hover:text-accent"
      >
        {categoryMeta?.emoji} {categoryMeta?.label}
      </a>
      <h1 class="mt-3 mb-4">{title}</h1>
      <p class="text-muted">{description}</p>

      <div class="mt-6 flex items-center gap-3 text-sm text-muted border-t border-border pt-4">
        <time datetime={publishedAt.toISOString()}>{fmt.format(publishedAt)} 발행</time>
        {
          updatedAt && (
            <>
              <span>·</span>
              <time datetime={updatedAt.toISOString()}>{fmt.format(updatedAt)} 업데이트</time>
            </>
          )
        }
        {experience && <span class="ml-auto text-accent">✓ 사장님 직접 사용</span>}
      </div>

      {
        affiliateLinks && (
          <p class="mt-3 text-xs text-muted bg-surface border border-border rounded px-3 py-2">
            이 글은 제휴 링크를 포함하고 있습니다. 사장님이 직접 써본 도구만 추천하며, 제휴 수익이 추천에 영향을 주지 않습니다.
          </p>
        )
      }
    </header>

    <div class="prose-magazine">
      <slot />
    </div>

    {
      tags.length > 0 && (
        <footer class="mt-12 pt-6 border-t border-border">
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="text-xs text-muted bg-surface border border-border rounded-full px-3 py-1">
                #{tag}
              </span>
            ))}
          </div>
        </footer>
      )
    }
  </article>

  <NewsletterCTA />
</BaseLayout>
