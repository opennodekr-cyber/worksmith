---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, type CategorySlug } from '@/consts';

export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({
    params: { category: cat.slug },
    props: { categorySlug: cat.slug, categoryLabel: cat.label, emoji: cat.emoji },
  }));
}

interface Props {
  categorySlug: CategorySlug;
  categoryLabel: string;
  emoji: string;
}

const { categorySlug, categoryLabel, emoji } = Astro.props;

const posts = (
  await getCollection('posts', ({ data }) => !data.draft && data.category === categorySlug)
).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<BaseLayout
  title={`${emoji} ${categoryLabel}`}
  description={`OPENNODE 매거진의 ${categoryLabel} 카테고리 글 모음`}
>
  <section class="container-wide py-12">
    <a href="/categories" class="text-sm text-muted no-underline hover:text-accent">
      ← 전체 카테고리
    </a>
    <h1 class="mt-3 mb-2">{emoji} {categoryLabel}</h1>
    <p class="text-muted mb-8">총 {posts.length}편</p>

    {
      posts.length === 0 ? (
        <p class="text-muted py-12 text-center">아직 이 카테고리에 글이 없습니다.</p>
      ) : (
        <div>{posts.map((post) => <PostCard post={post} />)}</div>
      )
    }
  </section>
</BaseLayout>
