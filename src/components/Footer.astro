---
import { SITE } from '@/consts';
const year = new Date().getFullYear();
---

<footer class="border-t border-border mt-20">
  <div class="container-wide py-10 flex flex-col md:flex-row md:justify-between gap-4 text-sm text-muted">
    <div>
      <div class="font-bold text-fg">{SITE.name}</div>
      <p class="mt-1">{SITE.tagline}</p>
      <p class="mt-2">
        <a href={SITE.parentUrl} target="_blank" rel="noopener" class="no-underline hover:text-fg">
          an {SITE.parent} company ↗
        </a>
      </p>
    </div>
    <div class="flex flex-col md:items-end gap-1">
      <span>© {year} {SITE.parent}</span>
      <a href="/rss.xml" class="no-underline hover:text-fg">RSS</a>
    </div>
  </div>
</footer>
